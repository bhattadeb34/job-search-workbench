# Copy this to secrets.toml locally, or paste into Streamlit Cloud → Settings → Secrets

# ── Google OAuth login (Streamlit built-in auth) ──────────────────────────────
# Get credentials at console.cloud.google.com → APIs & Services → Credentials
[auth]
redirect_uri  = "https://jobs-scraper.streamlit.app/oauth2callback"
cookie_secret = "replace-with-32-random-chars"   # generate at: passwordsgenerator.net

[auth.google]
client_id     = "your-client-id.apps.googleusercontent.com"
client_secret = "your-client-secret"

# ── App URL (used in waitlist notification emails) ────────────────────────────
APP_URL = "https://jobs-scraper.streamlit.app"

# ── AI (Google Gemini — free tier, get key at aistudio.google.com) ────────────
GEMINI_API_KEY = ""

# ── Email notification (Gmail App Password recommended) ───────────────────────
# Get an App Password at: https://myaccount.google.com/apppasswords
email_to   = ""
smtp_host  = "smtp.gmail.com"
smtp_port  = "587"
smtp_user  = ""   # your Gmail address
smtp_pass  = ""   # Gmail App Password
